// Pastas Orlando - Esquema de base de datos (Fase 13)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELOS ORIGINALES (FASE 1)
// ============================================

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  categoria   String
  precio      Float
  peso        String   @default("500g")
  imagen      String?
  stock       Boolean  @default(true)
  destacado   Boolean  @default(false)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Opinion {
  id              Int       @id @default(autoincrement())
  nombre          String
  calificacion    Int
  comentario      String
  estado          String    @default("pending")
  ip              String?
  fecha           DateTime  @default(now())
  fecha_aprobacion DateTime?
  id_aprobador    Int?
  respuesta       String?
  fecha_respuesta DateTime?
  destacado       Boolean   @default(false)
  orden           Int       @default(0)
}

model InteraccionWhatsApp {
  id              Int      @id @default(autoincrement())
  tipo            String
  mensaje_enviado String
  ip              String?
  fecha           DateTime @default(now())
}

// ============================================
// MÓDULO GEOGRÁFICO (base para direcciones)
// ============================================

model Pais {
  id         Int         @id @default(autoincrement())
  nombre     String      @unique
  provincias Provincia[]
  createdAt  DateTime    @default(now())
}

model Provincia {
  id            Int          @id @default(autoincrement())
  id_pais       Int
  nombre        String
  pais          Pais         @relation(fields: [id_pais], references: [id])
  departamentos Departamento[]
  createdAt     DateTime     @default(now())

  @@unique([id_pais, nombre])
}

model Departamento {
  id           Int       @id @default(autoincrement())
  id_provincia Int
  nombre       String
  provincia    Provincia @relation(fields: [id_provincia], references: [id])
  municipios   Municipio[]
  createdAt    DateTime  @default(now())

  @@unique([id_provincia, nombre])
}

model Municipio {
  id              Int          @id @default(autoincrement())
  id_departamento Int
  nombre          String
  departamento    Departamento @relation(fields: [id_departamento], references: [id])
  direcciones     Direccion[]
  personas        Persona[]
  createdAt       DateTime     @default(now())

  @@unique([id_departamento, nombre])
}

// ============================================
// MÓDULO PERSONAS (con tipos)
// ============================================

model TipoPersona {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  createdAt DateTime @default(now())
}

model Persona {
  id               Int       @id @default(autoincrement())
  id_municipio     Int?
  nombre           String
  apellido         String
  numero_documento String    @unique
  fecha_nacimiento DateTime?
  observaciones    String?
  tipo_persona     String
  razon_social     String?
  cuit             String?
  condicion_iva    String?
  imagen           String?
  fecha_registro   DateTime  @default(now())
  fecha_actualizacion DateTime? @updatedAt

  // Ubicación en mapa (FASE 12)
  latitud          Float?
  longitud         Float?
  direccion_mapa   String?
  ubicacion_valida Boolean   @default(false)

  // Relaciones
  municipio        Municipio?  @relation(fields: [id_municipio], references: [id])
  contactos        Contacto[]
  direcciones      Direccion[]
  usuario          Usuario?
  compras          Compra[]
  pedidosProveedor PedidoProveedor[]
  pedidosCliente   PedidoCliente[]
  reservasCliente  ReservaCliente[]
  ventas           Venta[]
  produccionesSupervisadas Produccion[] @relation("SupervisorProduccion")
  presupuestos     Presupuesto[]

  @@index([tipo_persona])
  @@index([numero_documento])
}

// ============================================
// CONTACTOS (múltiples por persona)
// ============================================

model TipoContacto {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  contactos Contacto[]
}

model Contacto {
  id              Int          @id @default(autoincrement())
  id_persona      Int
  id_tipo_contacto Int
  valor           String
  es_principal    Boolean      @default(false)
  verificado      Boolean      @default(false)
  persona         Persona      @relation(fields: [id_persona], references: [id], onDelete: Cascade)
  tipo            TipoContacto @relation(fields: [id_tipo_contacto], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime?    @updatedAt
}

// ============================================
// DIRECCIONES (múltiples por persona)
// ============================================

model TipoDireccion {
  id         Int        @id @default(autoincrement())
  nombre     String     @unique
  direcciones Direccion[]
}

model Direccion {
  id              Int           @id @default(autoincrement())
  id_persona      Int
  id_tipo_direccion Int
  id_municipio    Int?
  direccion       String
  referencia      String?
  latitud         Float?
  longitud        Float?
  es_principal    Boolean       @default(false)
  persona         Persona       @relation(fields: [id_persona], references: [id], onDelete: Cascade)
  tipo            TipoDireccion @relation(fields: [id_tipo_direccion], references: [id])
  municipio       Municipio?    @relation(fields: [id_municipio], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime?     @updatedAt
}

// ============================================
// USUARIOS (vinculados a Persona)
// ============================================

model Usuario {
  id               Int      @id @default(autoincrement())
  id_persona       Int      @unique
  email            String   @unique
  password         String
  estado           Boolean  @default(true)
  imagen           String?
  fecha_registro   DateTime @default(now())
  fecha_actualizacion DateTime? @updatedAt

  // Relaciones
  persona          Persona       @relation(fields: [id_persona], references: [id])
  roles            UsuarioRol[]
  sesiones         Sesion[]
  stockMovements   StockMovement[]
  ventas           Venta[]
  auditorias       Auditoria[]
  twoFactor        Usuario2FA?
  logsAcceso       LogAcceso[]
  sesionesActivas  SesionActiva[]

  @@index([email])
}

// ============================================
// ROLES Y PERMISOS
// ============================================

model Rol {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique  // admin, produccion, ventas, lectura
  descripcion String?
  es_default  Boolean      @default(false)
  usuarios    UsuarioRol[]
  permisos    RolPermiso[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
}

model UsuarioRol {
  id_usuario Int
  id_rol     Int
  usuario    Usuario @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  rol        Rol     @relation(fields: [id_rol], references: [id])

  @@id([id_usuario, id_rol])
}

model Permiso {
  id          Int         @id @default(autoincrement())
  nombre      String      @unique  // formato: modulo.accion (ej: productos.ver)
  descripcion String?
  modulo      String      @default("general") // productos, compras, ventas, produccion, usuarios, auditoria, reportes, seguridad
  roles       RolPermiso[]
  createdAt   DateTime    @default(now())

  @@index([modulo])
}

model RolPermiso {
  id_rol     Int
  id_permiso Int
  rol        Rol     @relation(fields: [id_rol], references: [id], onDelete: Cascade)
  permiso    Permiso @relation(fields: [id_permiso], references: [id], onDelete: Cascade)

  @@id([id_rol, id_permiso])
}

// ============================================
// SESIONES (auditoría)
// ============================================

model Sesion {
  id         Int      @id @default(autoincrement())
  id_usuario Int
  token      String
  ip         String?
  dispositivo String?
  fecha_inicio DateTime @default(now())
  fecha_fin  DateTime?
  usuario    Usuario  @relation(fields: [id_usuario], references: [id])
}

// ============================================
// UNIDADES DE MEDIDA (FASE 3)
// ============================================

model UnidadMedida {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  nombre          String
  conversion_a_base Float   @default(1.0)
  tipo_medida     String    // peso, volumen, longitud, unidad
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt

  // Relaciones
  materiasPrimas        MateriaPrima[]
  insumos               Insumo[]
  detalleRecetas        DetalleReceta[]
  detalleCompras        DetalleCompra[]
  detallePedidosProveedor DetallePedidoProveedor[]
  stockMovements        StockMovement[]
  detalleProduccionConsumo DetalleProduccionConsumo[]
}

// ============================================
// CATEGORÍAS DE MATERIAS PRIMAS (FASE 3)
// ============================================

model CategoriaMateriaPrima {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  // Relaciones
  materiasPrimas MateriaPrima[]
}

// ============================================
// MATERIAS PRIMAS (FASE 3)
// ============================================

model MateriaPrima {
  id                     Int       @id @default(autoincrement())
  codigo                 String?   @unique
  nombre                 String
  descripcion            String?
  id_categoria           Int
  id_unidad_base         Int
  stock_actual           Float     @default(0)
  stock_minimo           Float     @default(0)
  precio_compra_referencia Float   @default(0)
  imagen                 String?
  estado                 Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime? @updatedAt

  // Relaciones
  categoria       CategoriaMateriaPrima @relation(fields: [id_categoria], references: [id])
  unidadBase      UnidadMedida         @relation(fields: [id_unidad_base], references: [id])
  detalleRecetas  DetalleReceta[]
  detalleCompras  DetalleCompra[]
  detallePedidosProveedor DetallePedidoProveedor[]
  stockMovements  StockMovement[]
  detalleProduccionConsumo DetalleProduccionConsumo[]

  @@index([codigo])
  @@index([nombre])
}

// ============================================
// TIPOS DE INSUMOS (FASE 3)
// ============================================

model TipoInsumo {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  // Relaciones
  insumos Insumo[]
}

// ============================================
// INSUMOS (FASE 3)
// ============================================

model Insumo {
  id                     Int       @id @default(autoincrement())
  codigo                 String?   @unique
  nombre                 String
  descripcion            String?
  id_tipo_insumo         Int
  id_unidad_base         Int
  stock_actual           Float     @default(0)
  stock_minimo           Float     @default(0)
  precio_compra_referencia Float   @default(0)
  imagen                 String?
  estado                 Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime? @updatedAt

  // Relaciones
  tipoInsumo      TipoInsumo   @relation(fields: [id_tipo_insumo], references: [id])
  unidadBase      UnidadMedida @relation(fields: [id_unidad_base], references: [id])
  detalleRecetas  DetalleReceta[]
  detalleCompras  DetalleCompra[]
  detallePedidosProveedor DetallePedidoProveedor[]
  stockMovements  StockMovement[]
  detalleProduccionConsumo DetalleProduccionConsumo[]

  @@index([codigo])
  @@index([nombre])
}

// ============================================
// MARCAS (FASE 3)
// ============================================

model Marca {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  // Relaciones
  detalleCompras DetalleCompra[]
}

// ============================================
// CATEGORÍAS DE PRODUCTOS TERMINADOS (FASE 3)
// ============================================

model CategoriaProductoTerminado {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  // Relaciones
  productosTerminados ProductoTerminado[]
}

// ============================================
// PRODUCTOS TERMINADOS (FASE 3)
// ============================================

model ProductoTerminado {
  id                  Int       @id @default(autoincrement())
  codigo              String?   @unique
  nombre              String
  descripcion         String?
  id_categoria        Int
  peso_unitario_aprox Float     @default(0)
  precio_venta        Float     @default(0)
  stock_actual        Float     @default(0)
  stock_minimo        Float     @default(0)
  destacado           Boolean   @default(false)
  orden               Int       @default(0)
  visible_en_landing  Boolean   @default(true)
  imagen              String?
  estado              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime? @updatedAt

  // Relaciones
  categoria       CategoriaProductoTerminado @relation(fields: [id_categoria], references: [id])
  recetas         Receta[]
  stockMovements  StockMovement[]
  detallePedidosCliente DetallePedidoCliente[]
  detalleReservas ReservaCliente[]
  detalleVentas   DetalleVenta[]
  detalleProduccionGenerado DetalleProduccionGenerado[]
  detallePresupuesto DetallePresupuesto[]

  @@index([codigo])
  @@index([nombre])
}

// ============================================
// RECETAS (FASE 3 / FASE 6)
// ============================================

model Receta {
  id                    Int       @id @default(autoincrement())
  id_producto_terminado Int
  nombre_receta         String
  rendimiento_unidades  Int       @default(1)
  activo                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime? @updatedAt

  // Relaciones
  productoTerminado ProductoTerminado @relation(fields: [id_producto_terminado], references: [id])
  detalleRecetas    DetalleReceta[]
  producciones      Produccion[]
}

model DetalleReceta {
  id                  Int      @id @default(autoincrement())
  id_receta           Int
  id_materia_prima    Int?
  id_insumo           Int?
  cantidad_necesaria  Float
  id_unidad           Int
  costo_estimado      Float    @default(0)
  createdAt           DateTime @default(now())

  // Relaciones
  receta       Receta        @relation(fields: [id_receta], references: [id])
  materiaPrima MateriaPrima? @relation(fields: [id_materia_prima], references: [id])
  insumo       Insumo?       @relation(fields: [id_insumo], references: [id])
  unidad       UnidadMedida  @relation(fields: [id_unidad], references: [id])
}

// ============================================
// FORMAS DE PAGO (FASE 4)
// ============================================

model FormaPago {
  id                      Int      @id @default(autoincrement())
  nombre_forma            String   @unique
  requiere_identificacion Boolean  @default(false)
  requiere_cuenta         Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime? @updatedAt

  // Relaciones
  compras Compra[]
  ventas  Venta[]
}

// ============================================
// ESTADOS GENERALES (FASE 4)
// ============================================

model EstadoGeneral {
  id                Int      @id @default(autoincrement())
  nombre_estado     String   @unique
  entidad_aplicable String?
  es_final          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime? @updatedAt

  // Relaciones
  compras             Compra[]
  pedidosProveedor    PedidoProveedor[]
  pedidosCliente      PedidoCliente[]
  reservasCliente     ReservaCliente[]
  ventas              Venta[]
  producciones        Produccion[]
}

// ============================================
// COMPRAS A PROVEEDORES (FASE 4)
// ============================================

model Compra {
  id              Int      @id @default(autoincrement())
  id_proveedor    Int
  id_forma_pago   Int
  numero_factura  String?
  fecha_compra    DateTime
  subtotal        Float    @default(0)
  iva             Float    @default(0)
  total           Float    @default(0)
  id_estado       Int
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime? @updatedAt

  // Relaciones
  proveedor   Persona       @relation(fields: [id_proveedor], references: [id])
  formaPago   FormaPago     @relation(fields: [id_forma_pago], references: [id])
  estado      EstadoGeneral @relation(fields: [id_estado], references: [id])
  detalle     DetalleCompra[]

  @@index([fecha_compra])
  @@index([id_proveedor])
}

model DetalleCompra {
  id                      Int      @id @default(autoincrement())
  id_compra               Int
  id_materia_prima        Int?
  id_insumo               Int?
  id_marca                Int?
  cantidad_comprada       Float
  id_unidad_compra        Int
  precio_unitario         Float
  precio_total            Float
  fecha_vencimiento       DateTime?
  lote                    String?
  cantidad_base           Float    @default(0)
  precio_por_unidad_base  Float    @default(0)
  createdAt               DateTime @default(now())

  // Relaciones
  compra        Compra        @relation(fields: [id_compra], references: [id], onDelete: Cascade)
  materiaPrima  MateriaPrima? @relation(fields: [id_materia_prima], references: [id])
  insumo        Insumo?       @relation(fields: [id_insumo], references: [id])
  marca         Marca?        @relation(fields: [id_marca], references: [id])
  unidadCompra  UnidadMedida  @relation(fields: [id_unidad_compra], references: [id])

  @@index([id_compra])
}

// ============================================
// PEDIDOS A PROVEEDORES (FASE 4)
// ============================================

model PedidoProveedor {
  id                    Int       @id @default(autoincrement())
  id_proveedor          Int
  fecha_pedido          DateTime
  fecha_entrega_estimada DateTime?
  fecha_entrega_real    DateTime?
  observaciones         String?
  id_estado             Int
  total_estimado        Float     @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime? @updatedAt

  // Relaciones
  proveedor Persona         @relation(fields: [id_proveedor], references: [id])
  estado    EstadoGeneral   @relation(fields: [id_estado], references: [id])
  detalle   DetallePedidoProveedor[]

  @@index([fecha_pedido])
  @@index([id_proveedor])
}

model DetallePedidoProveedor {
  id              Int      @id @default(autoincrement())
  id_pedido       Int
  id_materia_prima Int?
  id_insumo       Int?
  cantidad_pedida Float
  id_unidad       Int
  precio_estimado Float   @default(0)
  createdAt       DateTime @default(now())

  // Relaciones
  pedido       PedidoProveedor @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  materiaPrima MateriaPrima?   @relation(fields: [id_materia_prima], references: [id])
  insumo       Insumo?         @relation(fields: [id_insumo], references: [id])
  unidad       UnidadMedida    @relation(fields: [id_unidad], references: [id])
}

// ============================================
// PEDIDOS DE CLIENTES (FASE 5)
// ============================================

model PedidoCliente {
  id                      Int      @id @default(autoincrement())
  id_cliente              Int
  fecha_pedido            DateTime
  fecha_entrega_solicitada DateTime
  fecha_entrega_real      DateTime?
  subtotal                Float    @default(0)
  total                   Float    @default(0)
  senia                   Float    @default(0)
  id_estado               Int
  observaciones           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime? @updatedAt

  // Relaciones
  cliente    Persona              @relation(fields: [id_cliente], references: [id])
  estado     EstadoGeneral        @relation(fields: [id_estado], references: [id])
  detalle    DetallePedidoCliente[]
  reservas   ReservaCliente[]
  venta      Venta?
  entregas   Entrega[]
  presupuesto Presupuesto?

  @@index([fecha_pedido])
  @@index([id_cliente])
}

model DetallePedidoCliente {
  id                    Int      @id @default(autoincrement())
  id_pedido             Int
  id_producto_terminado Int
  cantidad              Float
  precio_unitario       Float
  subtotal              Float
  createdAt             DateTime @default(now())

  // Relaciones
  pedido            PedidoCliente     @relation(fields: [id_pedido], references: [id], onDelete: Cascade)
  productoTerminado ProductoTerminado @relation(fields: [id_producto_terminado], references: [id])

  @@index([id_pedido])
}

// ============================================
// RESERVAS DE CLIENTES (FASE 5)
// ============================================

model ReservaCliente {
  id                    Int      @id @default(autoincrement())
  id_cliente            Int
  id_pedido             Int?
  fecha_reserva         DateTime
  fecha_validez_hasta   DateTime
  id_producto_terminado Int
  cantidad_reservada    Float
  cantidad_confirmada   Float    @default(0)
  senia                 Float    @default(0)
  id_estado             Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt

  // Relaciones
  cliente           Persona           @relation(fields: [id_cliente], references: [id])
  pedido            PedidoCliente?    @relation(fields: [id_pedido], references: [id])
  productoTerminado ProductoTerminado @relation(fields: [id_producto_terminado], references: [id])
  estado            EstadoGeneral     @relation(fields: [id_estado], references: [id])

  @@index([fecha_reserva])
  @@index([id_cliente])
}

// ============================================
// VENTAS (FASE 5)
// ============================================

model Venta {
  id                 Int      @id @default(autoincrement())
  id_cliente         Int
  id_vendedor        Int
  id_forma_pago      Int
  id_pedido          Int?      @unique
  numero_comprobante String?
  fecha_venta        DateTime
  subtotal           Float    @default(0)
  iva                Float    @default(0)
  total              Float    @default(0)
  id_estado          Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime? @updatedAt

  // Relaciones
  cliente   Persona        @relation(fields: [id_cliente], references: [id])
  vendedor  Usuario        @relation(fields: [id_vendedor], references: [id])
  formaPago FormaPago      @relation(fields: [id_forma_pago], references: [id])
  pedido    PedidoCliente? @relation(fields: [id_pedido], references: [id])
  estado    EstadoGeneral  @relation(fields: [id_estado], references: [id])
  detalle   DetalleVenta[]

  @@index([fecha_venta])
  @@index([id_cliente])
}

model DetalleVenta {
  id                    Int      @id @default(autoincrement())
  id_venta              Int
  id_producto_terminado Int
  cantidad              Float
  precio_unitario       Float
  subtotal              Float
  createdAt             DateTime @default(now())

  // Relaciones
  venta            Venta           @relation(fields: [id_venta], references: [id], onDelete: Cascade)
  productoTerminado ProductoTerminado @relation(fields: [id_producto_terminado], references: [id])

  @@index([id_venta])
}

// ============================================
// PRODUCCIÓN (FASE 6)
// ============================================

model Produccion {
  id                    Int      @id @default(autoincrement())
  id_receta             Int
  id_supervisor         Int?
  cantidad_producida    Int
  fecha_produccion      DateTime
  costo_total_materias_primas Float @default(0)
  costo_total_insumos   Float    @default(0)
  costo_total           Float    @default(0)
  id_estado             Int
  observaciones         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt

  // Relaciones
  receta                Receta         @relation(fields: [id_receta], references: [id])
  supervisor            Persona?       @relation("SupervisorProduccion", fields: [id_supervisor], references: [id])
  estado                EstadoGeneral  @relation(fields: [id_estado], references: [id])
  detalleConsumos       DetalleProduccionConsumo[]
  detalleGenerados      DetalleProduccionGenerado[]

  @@index([fecha_produccion])
  @@index([id_receta])
}

model DetalleProduccionConsumo {
  id                    Int      @id @default(autoincrement())
  id_produccion         Int
  id_materia_prima      Int?
  id_insumo             Int?
  cantidad_consumida    Float
  id_unidad             Int
  costo_unitario        Float
  costo_total           Float
  createdAt             DateTime @default(now())

  // Relaciones
  produccion            Produccion     @relation(fields: [id_produccion], references: [id], onDelete: Cascade)
  materiaPrima          MateriaPrima?  @relation(fields: [id_materia_prima], references: [id])
  insumo                Insumo?        @relation(fields: [id_insumo], references: [id])
  unidad                UnidadMedida   @relation(fields: [id_unidad], references: [id])

  @@index([id_produccion])
}

model DetalleProduccionGenerado {
  id                    Int      @id @default(autoincrement())
  id_produccion         Int
  id_producto_terminado Int
  cantidad_generada     Float
  costo_unitario        Float
  costo_total           Float
  createdAt             DateTime @default(now())

  // Relaciones
  produccion            Produccion        @relation(fields: [id_produccion], references: [id], onDelete: Cascade)
  productoTerminado     ProductoTerminado @relation(fields: [id_producto_terminado], references: [id])

  @@index([id_produccion])
}

// ============================================
// STOCK MOVEMENTS / AUDITORÍA (FASE 3)
// ============================================

model StockMovement {
  id                    Int      @id @default(autoincrement())
  tipo_movimiento       String   // compra, venta, produccion_consumo, produccion_genera, ajuste_in, ajuste_out, devolucion
  id_materia_prima      Int?
  id_insumo             Int?
  id_producto_terminado Int?
  cantidad              Float
  id_unidad             Int
  stock_antes           Float
  stock_despues         Float
  referencia_id         Int?
  referencia_tabla      String?
  observacion           String?
  id_usuario            Int?
  fecha_movimiento      DateTime @default(now())

  // Relaciones
  materiaPrima       MateriaPrima?     @relation(fields: [id_materia_prima], references: [id])
  insumo             Insumo?           @relation(fields: [id_insumo], references: [id])
  productoTerminado  ProductoTerminado? @relation(fields: [id_producto_terminado], references: [id])
  unidad             UnidadMedida      @relation(fields: [id_unidad], references: [id])
  usuario            Usuario?          @relation(fields: [id_usuario], references: [id])
}

// ============================================
// AUTENTICACIÓN 2FA (FASE 9)
// ============================================

model Usuario2FA {
  id               Int       @id @default(autoincrement())
  id_usuario       Int       @unique
  secret_2fa       String?   // secreto TOTP (null si no está activado)
  activado         Boolean   @default(false)
  codigos_respaldo String?   // códigos de respaldo (JSON array string)
  fecha_activacion DateTime?
  fecha_ultimo_uso DateTime?

  usuario          Usuario   @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
}

// ============================================
// LOGS DE ACCESO (FASE 9)
// ============================================

model LogAcceso {
  id                Int      @id @default(autoincrement())
  id_usuario        Int?
  email_intento     String?
  resultado         String   // OK, FAIL, BLOCKED, 2FA_REQUIRED, 2FA_OK, 2FA_FAIL
  ip                String?
  user_agent        String?
  navegador         String?
  sistema_operativo String?
  dispositivo       String?
  pais              String?
  ciudad            String?
  motivo            String?
  fecha             DateTime @default(now())

  usuario           Usuario? @relation(fields: [id_usuario], references: [id])

  @@index([fecha])
  @@index([email_intento])
  @@index([resultado])
}

// ============================================
// SESIONES ACTIVAS (FASE 9)
// ============================================

model SesionActiva {
  id_sesion        String   @id
  id_usuario       Int
  ip               String?
  user_agent       String?
  fecha_inicio     DateTime @default(now())
  fecha_expiracion DateTime
  fecha_fin        DateTime?
  estado           String   @default("active") // active, expired, revoked

  usuario          Usuario  @relation(fields: [id_usuario], references: [id], onDelete: Cascade)

  @@index([id_usuario])
  @@index([estado])
}

// ============================================
// AUDITORÍA (FASE 8)
// ============================================

model Auditoria {
  id              Int      @id @default(autoincrement())
  id_usuario      Int?
  accion          String   // CREATE, UPDATE, DELETE, LOGIN_OK, LOGIN_FAIL, LOGOUT, EXPORT, VIEW
  modulo          String   // productos, compras, ventas, produccion, usuarios, reportes, login
  entidad_id      Int?
  entidad_nombre  String?
  detalles        String?  // JSON string con cambios antes/después
  ip              String?
  user_agent      String?
  fecha           DateTime @default(now())

  usuario         Usuario? @relation(fields: [id_usuario], references: [id])

  @@index([fecha])
  @@index([modulo])
  @@index([accion])
  @@index([id_usuario])
}

// ============================================
// ENVÍOS Y LOGÍSTICA (FASE 10)
// ============================================

model PuntoEncuentro {
  id          Int      @id @default(autoincrement())
  nombre      String
  direccion   String
  latitud     Float?
  longitud    Float?
  horarios    String?  // JSON con horarios disponibles
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entregas    Entrega[]
}

model Entrega {
  id                  Int      @id @default(autoincrement())
  id_pedido           Int
  id_punto_encuentro  Int?
  direccion_alternativa String?
  fecha_programada    DateTime
  fecha_realizada     DateTime?
  hora_desde          String?
  hora_hasta          String?
  nombre_recibe       String?
  telefono_recibe     String?
  estado              String   @default("programado") // programado, en_camino, entregado, cancelado, reagendado
  observaciones       String?
  latitud_entrega     Float?
  longitud_entrega    Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  pedido              PedidoCliente   @relation(fields: [id_pedido], references: [id])
  puntoEncuentro      PuntoEncuentro? @relation(fields: [id_punto_encuentro], references: [id])
  notificaciones      NotificacionEntrega[]

  @@index([fecha_programada])
  @@index([estado])
}

model NotificacionEntrega {
  id           Int      @id @default(autoincrement())
  id_entrega   Int
  tipo         String   // recordatorio, confirmacion, retraso, completado
  canal        String   // whatsapp, email
  destinatario String
  mensaje      String
  estado       String   // pendiente, enviado, error
  fecha_envio  DateTime?
  error        String?
  createdAt    DateTime @default(now())

  entrega      Entrega  @relation(fields: [id_entrega], references: [id], onDelete: Cascade)

  @@index([id_entrega])
}

// ============================================
// NOTIFICACIONES (FASE 11)
// ============================================

model PlantillaNotificacion {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique  // pedido_confirmado, stock_bajo, entrega_recordatorio, etc.
  canal       String   // email, whatsapp, ambos
  asunto      String?  // para email
  mensaje     String   // plantilla con variables {{nombre}}, {{pedido}}, etc.
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notificaciones Notificacion[]
}

model Notificacion {
  id               Int      @id @default(autoincrement())
  id_plantilla     Int?
  tipo             String   // email, whatsapp
  destinatario     String
  asunto           String?
  mensaje          String
  estado           String   @default("pendiente") // pendiente, enviado, error, cancelado
  fecha_programada DateTime?
  fecha_envio      DateTime?
  error            String?
  metadata         String?  // JSON string con datos adicionales (pedido_id, producto_id, etc.)
  createdAt        DateTime @default(now())

  plantilla        PlantillaNotificacion? @relation(fields: [id_plantilla], references: [id])

  @@index([estado])
  @@index([tipo])
  @@index([createdAt])
}

model AlertaConfiguracion {
  id              Int      @id @default(autoincrement())
  tipo            String   @unique // stock_bajo, pedido_pendiente, produccion_atrasada, entrega_proxima
  activo          Boolean  @default(true)
  umbral          Int?     // para stock: porcentaje o cantidad mínima
  destinatarios   String?  // emails o teléfonos (JSON array string)
  frecuencia      String?  // inmediato, diario, semanal
  ultimo_envio    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// TABLAS DE REFERENCIA ADICIONALES
// ============================================

model EmpresaTelefonica {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  codigo    String?  @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

model ServicioCorreoElectronico {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  dominio   String?  @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

model TipoPlataforma {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  descripcion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

model TipoEntidad {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  descripcion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

model EstadoSesion {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  descripcion String?
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

// ============================================
// PRESUPUESTOS / COTIZACIONES (FASE 13)
// ============================================

model Presupuesto {
  id              Int      @id @default(autoincrement())
  id_cliente      Int
  numero          String   @unique
  fecha_creacion  DateTime @default(now())
  fecha_validez   DateTime
  subtotal        Float    @default(0)
  iva             Float    @default(0)
  total           Float    @default(0)
  observaciones   String?
  estado          String   @default("pendiente") // pendiente, aprobado, rechazado, expirado, convertido
  id_pedido       Int?     @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  cliente         Persona         @relation(fields: [id_cliente], references: [id])
  pedido          PedidoCliente?  @relation(fields: [id_pedido], references: [id])
  detalle         DetallePresupuesto[]

  @@index([numero])
  @@index([id_cliente])
  @@index([estado])
}

model DetallePresupuesto {
  id                    Int      @id @default(autoincrement())
  id_presupuesto        Int
  id_producto_terminado Int
  cantidad              Float
  precio_unitario       Float
  subtotal              Float
  observaciones         String?
  createdAt             DateTime @default(now())

  // Relaciones
  presupuesto           Presupuesto       @relation(fields: [id_presupuesto], references: [id], onDelete: Cascade)
  productoTerminado     ProductoTerminado @relation(fields: [id_producto_terminado], references: [id])

  @@index([id_presupuesto])
}
